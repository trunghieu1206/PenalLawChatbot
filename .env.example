# PenalLawChatbot — Environment Variables
# Copy this file to .env on the server, then fill in ONLY:
#   - OPENROUTER_API_KEY  (get from openrouter.ai)
#   - HF_TOKEN            (get from huggingface.co/settings/tokens)
# Everything else is pre-filled with correct defaults.

# ---- REQUIRED: fill these two ----
OPENROUTER_API_KEY=your_openrouter_api_key_here
HF_TOKEN=your_huggingface_token_here

# ---- PRE-FILLED: do not change unless you know what you're doing ----
JWT_SECRET=j1WQjbYqkjImzp0etlJQRgI4alxtRxGTgAJalevJKKDAuuHFm2gbPNXcRxMzYNQ1nUJd6hYNVPkScjrEZr0aGA==

# ---- POSTGRESQL ----
POSTGRES_DB=penallaw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# AI service settings (COLLECTION_NAME, EMBEDDING_ADAPTER, LLM_MODEL, TOP_K, FORCE_CPU)
# are configured directly in ai-service/app/main.py — no need to set them here.
